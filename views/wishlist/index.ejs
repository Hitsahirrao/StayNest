<% layout("/layouts/boilerplate") %>

<h3 class="mt-3 mb-3">My Wishlist</h3>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
  <% if (wishlist.length === 0) { %>
    <h5>No listings added to wishlist yet.</h5>
  <% } %>

  <% for (let listing of wishlist) { %>
    <div class="card col listing-card">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br>
            ₹ <%= listing.price.toLocaleString("en-IN") %> / night
          </p>
        </div>
      </a>

      <form method="POST" action="/wishlist/<%= listing._id %>/remove">
        <button class="btn btn-sm btn-outline-danger mb-3">Remove</button>
      </form>
    </div>
  <% } %>
</div>