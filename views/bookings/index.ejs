<% layout("/layouts/boilerplate") %>

<h3 class="mt-3 mb-3">My Bookings</h3>

<% if (bookings.length === 0) { %>
  <h5>No bookings yet.</h5>
<% } %>

<div class="row">
  <% for (let booking of bookings) { %>
    <% if (booking.listing) { %>
      <div class="card col-6 offset-3 mb-3">
        <img src="<%= booking.listing.image.url %>" class="card-img-top" style="height: 20rem; object-fit: cover;">
        <div class="card-body">
          <h5><%= booking.listing.title %></h5>
          <p>Check-in: <%= booking.checkIn.toDateString() %></p>
          <p>Check-out: <%= booking.checkOut.toDateString() %></p>
          <p>Total Price: ₹ <%= booking.totalPrice.toLocaleString("en-IN") %></p>
          <p>Status: <b><%= booking.status %></b></p>

          <% if (booking.status !== "cancelled") { %>
            <form method="POST" action="/bookings/<%= booking._id %>/cancel">
              <button class="btn btn-outline-danger">Cancel Booking</button>
            </form>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>
</div>